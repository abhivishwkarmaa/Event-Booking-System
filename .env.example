NODE_ENV=development
PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=app_secret
DB_NAME=event_booking
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Docker Compose only — MySQL container root password (healthcheck)
MYSQL_ROOT_PASSWORD=root

# Docker Compose — host port for MySQL (default 3307 if 3306 is already used by system MySQL)
MYSQL_PUBLISH_PORT=3307
